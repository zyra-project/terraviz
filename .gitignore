# Dependencies
node_modules/
pnpm-lock.yaml
yarn.lock

# Build outputs
dist/
build/
*.tsbuildinfo
src-tauri/target/
# Generated platform scaffolding — created by `tauri android init`
# / `tauri ios init` from src-tauri/Cargo.toml + tauri.conf.json.
# CI regenerates these in .github/workflows/mobile.yml before the
# build runs; locally, `npm run dev:android` / `npm run dev:ios`
# does the same on first invocation. Untracking keeps the repo
# clean of platform-specific Gradle / Xcode artefacts that change
# on every Tauri version bump.
src-tauri/gen/
src/styles/tokens.css
# Generated by `npm run locales` from locales/*.json; see docs/I18N_PLAN.md
src/i18n/messages.ts
src/i18n/messages.*.ts

# Test / coverage artifacts
coverage/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.env.local
.env.*.local

# Working files
_work/
.claude/

# Development
.cache/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
.playwright-mcp/

# Local MCP client config — Claude Code reads `.mcp.json` at the
# repo root for project-scoped MCP server connections. Per-contributor;
# typically contains auth tokens (e.g. Penpot MCP). Never commit.
# A redacted `.mcp.json.example` may be committed as a template.
.mcp.json

# Runtime
.turbo/

# Wrangler local state — Miniflare D1/KV/R2/Queues volumes generated
# by `wrangler pages dev` and `wrangler d1 ... --local`. Per-contributor,
# never committed.
.wrangler/
.dev.vars
.dev.vars.local
# Vite reads `.env.local` at the repo root (envDir override in
# vite.config.ts). Per-developer values; never committed.
.env.local
.env.*.local
# Output of `npm run gen:node-key`; the wire-format public key is
# also persisted in node_identity.public_key, so this file is just
# a convenience for paste-into-portal flows.
node-public-key.txt

# Test / coverage artifacts
coverage/
.terraviz/prod.env

# Graphify knowledge-graph output — generated by the `graphify`
# code-graph tool (graph.json / graph.html / GRAPH_REPORT.md + caches).
# Regenerable from source, multi-MB, per-developer. Never committed.
graphify-out/
