{
  "name": "interactive-sphere",
  "version": "0.2.2",
  "type": "module",
  "description": "Interactive WebGL globe with adaptive bitrate environmental data streaming",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && typedoc",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "build:qa": "npx tsx scripts/build-qa-index.ts",
    "tauri": "tauri",
    "dev:desktop": "tauri dev",
    "build:desktop": "tsc && vite build && tauri build",
    "dev:ios": "tauri ios dev",
    "dev:android": "tauri android dev",
    "build:ios": "tsc && vite build && tauri ios build",
    "build:android": "tsc && vite build && tauri android build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "^2.4.8",
    "@tauri-apps/plugin-http": "^2.5.8",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "axios": "^1.6.0",
    "hls.js": "^1.4.0",
    "html2canvas": "^1.4.1",
    "maplibre-gl": "^5.21.1"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-musl": "^1.0.0-rc.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^20.8.4",
    "sharp": "^0.34.5",
    "typedoc": "^0.28.18",
    "typescript": "^5.3.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
