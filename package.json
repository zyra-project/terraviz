{
  "name": "terraviz",
  "version": "0.6.0",
  "type": "module",
  "description": "Terraviz — WebGL globe with adaptive bitrate environmental data streaming",
  "bin": {
    "terraviz": "./bin/terraviz.cjs"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "tokens": "style-dictionary build --config tokens/style-dictionary.config.mjs",
    "locales": "npx tsx scripts/generate-locales.ts",
    "check:locales": "npx tsx scripts/generate-locales.ts --check",
    "check:i18n-strings": "npx tsx scripts/check-i18n-strings.ts",
    "sync:weblate": "npx tsx scripts/sync-weblate-metadata.ts",
    "screenshots:capture": "npx tsx scripts/screenshots/capture.ts",
    "screenshots:report": "npx tsx scripts/screenshots/report.ts",
    "screenshots:diff": "npx tsx scripts/screenshots/diff.ts",
    "screenshots:smoke": "npx tsx scripts/screenshots/smoke.ts",
    "screenshots:summary": "npx tsx scripts/screenshots/summary.ts",
    "screenshots:sync": "npx tsx scripts/sync-weblate-screenshots.ts",
    "postinstall": "npm run tokens && npm run locales",
    "predev": "npm run build:privacy-page && npm run locales",
    "dev": "vite",
    "prebuild": "npm run build:privacy-page && npm run locales",
    "build": "npm run tokens && npm run locales && tsc && vite build && typedoc",
    "docs": "typedoc",
    "docs:tokens": "node tokens/scripts/update-style-guide.mjs",
    "docs:watch": "typedoc --watch",
    "preview": "vite preview",
    "check:migrations": "npx tsx scripts/check-migrations-additive.ts",
    "check:doc-coverage": "npx tsx scripts/check-doc-coverage.ts",
    "type-check": "npm run locales && npm run check:i18n-strings && npm run check:migrations && npm run check:doc-coverage && tsc --noEmit && tsc --noEmit -p functions/tsconfig.json && tsc --noEmit -p cli/tsconfig.json",
    "terraviz": "tsx cli/terraviz.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "build:qa": "npx tsx scripts/build-qa-index.ts",
    "build:privacy-page": "npx tsx scripts/build-privacy-page.ts",
    "check:privacy-page": "npx tsx scripts/build-privacy-page.ts --check",
    "check:design-roundtrip": "npx tsx scripts/check-design-roundtrip.ts",
    "dev:functions": "wrangler pages dev public --ip 0.0.0.0 --port 8788",
    "db:migrate": "wrangler d1 migrations apply CATALOG_DB --local",
    "db:seed": "tsx scripts/seed-catalog.ts",
    "db:reset": "tsx scripts/clean-d1-state.ts && npm run db:migrate && npm run db:seed",
    "db:dump-schema": "tsx scripts/dump-catalog-schema.ts",
    "gen:node-key": "tsx scripts/gen-node-key.ts",
    "check:pages-bindings": "tsx scripts/check-pages-bindings.ts",
    "refresh:sos-snapshot": "tsx scripts/refresh-sos-snapshot.ts",
    "tauri": "tauri",
    "dev:desktop": "tauri dev",
    "build:desktop": "tsc && vite build && tauri build",
    "dev:ios": "tauri ios dev",
    "dev:android": "tauri android dev",
    "build:ios": "tsc && vite build && tauri ios build",
    "build:android": "tsc && vite build && tauri android build"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "^2.4.8",
    "@tauri-apps/plugin-http": "^2.5.8",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "aws4fetch": "^1.0.20",
    "axios": "^1.16.0",
    "cytoscape": "^3.33.4",
    "cytoscape-cola": "^2.5.1",
    "d3-axis": "^3.0.0",
    "d3-brush": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "hls.js": "^1.4.0",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "maplibre-gl": "^5.21.1",
    "three": "^0.183.2",
    "tsx": "^4.21.0",
    "yaml": "^2.9.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-musl": "^1.0.0-rc.11"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "form-data": "^4.0.6",
    "markdown-it": "^14.2.0",
    "ws": "^8.20.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tauri-apps/cli": "^2",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-brush": "^3.0.6",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^20.10.0",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^4.1.0",
    "axe-core": "^4.12.1",
    "better-sqlite3": "^11.10.0",
    "happy-dom": "^20.8.9",
    "marked": "^18.0.2",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "style-dictionary": "^5.4.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.3.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.0",
    "wrangler": "^4.98.0"
  }
}
