{
  "name": "interactive-sphere",
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive WebGL globe with adaptive bitrate environmental data streaming",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "hls.js": "^1.4.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/three": "^0.160.0",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^20.8.4",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
