{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window. Desktop only — includes localhost/cleartext exceptions for local LLM servers (Ollama, LM Studio, llama.cpp). Mobile uses capabilities/mobile.json instead.",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-available-monitors",
    "core:window:allow-current-monitor",
    "updater:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" },
        { "url": "http://*:11434" },
        { "url": "http://*:1234" },
        { "url": "http://*:8080" },
        { "url": "https://*" }
      ]
    }
  ]
}
