{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/public/api/spec/dashboard.json",
  "title": "Terraviz — Spatial Attention",
  "uid": "terraviz-spatial-attention",
  "tags": [
    "terraviz",
    "analytics",
    "tier-a",
    "spatial"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 7,
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "label": "Environment",
        "query": "production,preview,local",
        "current": {
          "text": "production",
          "value": "production"
        }
      },
      {
        "name": "internal",
        "type": "custom",
        "label": "Internal staff?",
        "query": "false,true",
        "current": {
          "text": "false",
          "value": "false"
        }
      },
      {
        "name": "projection",
        "type": "custom",
        "label": "Projection",
        "query": "globe,mercator,vr,ar",
        "current": {
          "text": "globe",
          "value": "globe"
        },
        "multi": true,
        "includeAll": true
      },
      {
        "name": "layer_id",
        "type": "custom",
        "label": "Layer (dataset)",
        "query": "$__all",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "multi": false,
        "includeAll": true,
        "description": "Defaults to All. Convert to a query variable in-Grafana once data is flowing — Infinity query: SELECT DISTINCT blob5 FROM terraviz_events WHERE blob1 = 'camera_settled' AND blob5 != '' ORDER BY blob5"
      },
      {
        "name": "zoom_bucket",
        "type": "custom",
        "label": "Zoom bucket",
        "description": "Camera-settle altitude filter. `zoom` is reported in MapLibre's logarithmic scale: 0 ≈ whole-world view, ~3 ≈ continental, ~6 ≈ country, ~10 ≈ city, ~14 ≈ neighborhood. Each bucket value is an SQL fragment substituted into the heatmap WHERE clause.",
        "query": "All : 1=1,Wide (zoom 0-3, continental) : double6 < 4,Mid (zoom 4-7, country to metro) : double6 >= 4 AND double6 < 8,Close (zoom 8+, city to street) : double6 >= 8",
        "current": {
          "text": "All",
          "value": "1=1"
        }
      },
      {
        "name": "DS_INFINITY",
        "type": "datasource",
        "query": "yesoreyeram-infinity-datasource",
        "label": "Data source"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "geomap",
      "title": "camera_settled heatmap (0.1° bins, $zoom_bucket)",
      "description": "Hex bins of camera-settle locations. Filtered to selected projection, zoom bucket, and (optionally) layer_id. Coordinates pre-rounded to 3 decimals (~110 m) at the client; bin size here is 0.1° (~11 km at the equator). Switch the Zoom bucket dropdown to facet by camera altitude — Wide tells you continental dwell, Close tells you city-level attention.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 18,
        "h": 14
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_INFINITY}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "${DS_INFINITY}"
          },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "/sql",
          "url_options": {
            "method": "POST",
            "data": "SELECT round(double3, 1) AS lon_bin, round(double2, 1) AS lat_bin, count() AS settles FROM terraviz_events WHERE blob1 = 'camera_settled' AND blob6 IN (${projection:singlequote}) AND blob2 = '$environment' AND blob4 = '$internal' AND ('$layer_id' = '$__all' OR blob5 = '$layer_id') AND ($zoom_bucket) AND timestamp > toDateTime(intDiv($__from, 1000)) GROUP BY lat_bin, lon_bin HAVING settles > 5 ORDER BY settles DESC LIMIT 5000",
            "headers": [
              {
                "key": "Content-Type",
                "value": "text/plain"
              }
            ]
          },
          "parser": "backend",
          "root_selector": "data",
          "columns": [
            {
              "selector": "lon_bin",
              "text": "lon_bin",
              "type": "number"
            },
            {
              "selector": "lat_bin",
              "text": "lat_bin",
              "type": "number"
            },
            {
              "selector": "settles",
              "text": "settles",
              "type": "number"
            }
          ]
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total camera_settled events",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_INFINITY}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "${DS_INFINITY}"
          },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "/sql",
          "url_options": {
            "method": "POST",
            "data": "SELECT count() AS settles FROM terraviz_events WHERE blob1 = 'camera_settled' AND blob6 IN (${projection:singlequote}) AND blob2 = '$environment' AND blob4 = '$internal' AND ('$layer_id' = '$__all' OR blob5 = '$layer_id') AND ($zoom_bucket) AND timestamp > toDateTime(intDiv($__from, 1000))",
            "headers": [
              {
                "key": "Content-Type",
                "value": "text/plain"
              }
            ]
          },
          "parser": "backend",
          "root_selector": "data",
          "columns": [
            {
              "selector": "settles",
              "text": "settles",
              "type": "number"
            }
          ]
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total map_click events",
      "gridPos": {
        "x": 18,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_INFINITY}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "${DS_INFINITY}"
          },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "/sql",
          "url_options": {
            "method": "POST",
            "data": "SELECT count() AS clicks FROM terraviz_events WHERE blob1 = 'map_click' AND blob2 = '$environment' AND blob4 = '$internal' AND timestamp > toDateTime(intDiv($__from, 1000))",
            "headers": [
              {
                "key": "Content-Type",
                "value": "text/plain"
              }
            ]
          },
          "parser": "backend",
          "root_selector": "data",
          "columns": [
            {
              "selector": "clicks",
              "text": "clicks",
              "type": "number"
            }
          ]
        }
      ]
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "map_click hit-kind mix",
      "description": "Where on the map users click — bare surface vs marker vs feature vs region overlay.",
      "gridPos": {
        "x": 18,
        "y": 8,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_INFINITY}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "${DS_INFINITY}"
          },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "/sql",
          "url_options": {
            "method": "POST",
            "data": "SELECT blob6 AS hit_kind, count() AS clicks FROM terraviz_events WHERE blob1 = 'map_click' AND blob2 = '$environment' AND blob4 = '$internal' AND timestamp > toDateTime(intDiv($__from, 1000)) GROUP BY hit_kind ORDER BY clicks DESC",
            "headers": [
              {
                "key": "Content-Type",
                "value": "text/plain"
              }
            ]
          },
          "parser": "backend",
          "root_selector": "data",
          "columns": [
            {
              "selector": "hit_kind",
              "text": "hit_kind",
              "type": "string"
            },
            {
              "selector": "clicks",
              "text": "clicks",
              "type": "number"
            }
          ]
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Top viewed regions per dataset",
      "description": "Hex bins of camera_settled + map_click events, scoped to a loaded dataset. Joint attention signal — both 'where users park the camera' and 'where they tap'.",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_INFINITY}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "${DS_INFINITY}"
          },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "/sql",
          "url_options": {
            "method": "POST",
            "data": "SELECT blob5 AS layer_id, round(double3, 1) AS lon_bin, round(double2, 1) AS lat_bin, count() AS attention_events FROM terraviz_events WHERE blob1 IN ('camera_settled', 'map_click') AND blob2 = '$environment' AND blob4 = '$internal' AND blob5 != '' AND timestamp > toDateTime(intDiv($__from, 1000)) GROUP BY layer_id, lat_bin, lon_bin HAVING attention_events > 10 ORDER BY attention_events DESC LIMIT 200",
            "headers": [
              {
                "key": "Content-Type",
                "value": "text/plain"
              }
            ]
          },
          "parser": "backend",
          "root_selector": "data",
          "columns": [
            {
              "selector": "layer_id",
              "text": "layer_id",
              "type": "string"
            },
            {
              "selector": "lon_bin",
              "text": "lon_bin",
              "type": "number"
            },
            {
              "selector": "lat_bin",
              "text": "lat_bin",
              "type": "number"
            },
            {
              "selector": "attention_events",
              "text": "attention_events",
              "type": "number"
            }
          ]
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "2D vs VR/AR — same dataset",
      "description": "When a dataset is opened in both surfaces, are users navigating to the same regions? Compare camera_settled counts split by projection.",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_INFINITY}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "${DS_INFINITY}"
          },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "/sql",
          "url_options": {
            "method": "POST",
            "data": "SELECT blob6 AS projection, blob5 AS layer_id, count() AS settles FROM terraviz_events WHERE blob1 = 'camera_settled' AND blob5 != '' AND blob2 = '$environment' AND blob4 = '$internal' AND timestamp > toDateTime(intDiv($__from, 1000)) GROUP BY projection, layer_id ORDER BY settles DESC LIMIT 50",
            "headers": [
              {
                "key": "Content-Type",
                "value": "text/plain"
              }
            ]
          },
          "parser": "backend",
          "root_selector": "data",
          "columns": [
            {
              "selector": "projection",
              "text": "projection",
              "type": "string"
            },
            {
              "selector": "layer_id",
              "text": "layer_id",
              "type": "string"
            },
            {
              "selector": "settles",
              "text": "settles",
              "type": "number"
            }
          ]
        }
      ]
    }
  ]
}
