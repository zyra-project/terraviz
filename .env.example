# Frontend env vars — copy to `.env.local` (gitignored) and edit.
# Vite reads this file from the repo root at server start.
# Anything not set falls back to the documented default.

# --- Catalog source -----------------------------------------------
# `node` (default, post-1d cutover) pulls from this deployment's
# own `/api/v1/catalog`. `legacy` falls back to the SOS S3 path
# and is the rollback recipe for the cutover stabilisation window.
# VITE_CATALOG_SOURCE=legacy

# --- Dev-server proxy ---------------------------------------------
# Where the Vite dev server forwards `/api/*` requests to.
# Defaults to the production catalog. Set to your local wrangler
# port to develop the frontend against the local backend:
# VITE_DEV_API_TARGET=http://localhost:8788

# --- Dev-server host / HMR (dev-container friendly) ---------------
# Bind Vite to all interfaces so a dev container's host browser can
# reach it. Default `localhost` when unset is fine on host shells.
# VITE_HOST=0.0.0.0
#
# When the host browser connects through forwarded ports rather
# than the same hostname Vite advertises, the HMR WebSocket fails
# unless the client port is set explicitly.
# VITE_HMR_CLIENT_PORT=5173

# --- Telemetry (existing) -----------------------------------------
# `true` logs telemetry to console instead of POSTing.
# VITE_TELEMETRY_CONSOLE=
# `false` compiles out the emitter entirely.
# VITE_TELEMETRY_ENABLED=

# --- Build channel (existing) -------------------------------------
# `internal` / `canary` tag the bundle so dashboards filter them
# out of public-user rollups.
# VITE_BUILD_CHANNEL=
